{
  "name": "korex",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "drizzle-orm": "^0.45.1",
      "vitest": "^4.1.5",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@orpc/server": "^1.13.14",
      "@orpc/openapi": "^1.13.14",
      "@orpc/zod": "^1.13.14",
      "better-auth": "1.5.5",
      "effect": "^3.21.2",
      "next-themes": "^0.4.6",
      "@orpc/client": "^1.13.14",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "test:integration": "turbo -F tests test:integration",
    "test:integration:clean": "tutegration:clean",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "test": "turbo test",
    "db:push": "turbo -F @korex/db db:push",
    "db:studio": "turbo -F @korex/db db:studio",
    "db:generate": "turbo -F @korex/db db:generate",
    "db:migrate": "turbo -F @korex/db db:migrate",
    "db:start": "turbo -F @korex/db db:start",
    "db:watch": "turbo -F @korex/db db:watch",
    "db:stop": "turbo -F @korex/db db:stop",
    "db:down": "turbo -F @korex/db db:down",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@korex/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@korex/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.11"
}
