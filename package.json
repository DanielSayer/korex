{
  "name": "korex",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "pnpm run start:server",
    "start:server": "pnpm --filter server run start",
    "start:worker": "pnpm --filter worker run start",
    "start:web": "pnpm --filter web run serve --host 0.0.0.0 --port $PORT",
    "check-types": "turbo check-types",
    "test:integration": "turbo -F tests test:integration",
    "test:integration:clean": "pnpm --filter tests run test:integration:clean",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "test": "turbo test",
    "db:push": "turbo -F @korex/db db:push",
    "db:studio": "turbo -F @korex/db db:studio",
    "db:generate": "turbo -F @korex/db db:generate",
    "db:migrate": "turbo -F @korex/db db:migrate",
    "db:start": "turbo -F @korex/db db:start",
    "db:watch": "turbo -F @korex/db db:watch",
    "db:stop": "turbo -F @korex/db db:stop",
    "db:down": "turbo -F @korex/db db:down",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@korex/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@korex/config": "workspace:*",
    "@types/node": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@9.5.0"
}
